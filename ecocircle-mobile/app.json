{
  "expo": {
    "name": "EcoCircle",
    "slug": "ecocircle-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2d6a4f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ecocircle.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2d6a4f"
      },
      "package": "com.ecocircle.mobile"
    },
    "extra": {},
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
