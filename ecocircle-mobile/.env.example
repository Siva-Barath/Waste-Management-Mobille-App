# API Configuration
# Replace YOUR_COMPUTER_IP with your actual computer's local IP address
# To find your IP: 
# - Windows: Open Command Prompt and run "ipconfig"
# - Mac/Linux: Open Terminal and run "ifconfig" or "ip a"
# Look for the IPv4 address (usually starts with 192.168.x.x or 10.x.x.x)

EXPO_PUBLIC_API_URL=http://YOUR_COMPUTER_IP:5000/api
